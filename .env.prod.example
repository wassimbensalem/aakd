# ClauseFlow — Production environment variables
# Copy this to .env.prod and fill every value before deploying.
# The deploy.sh script auto-generates the secret values for you.

# ── Domain ────────────────────────────────────────────────────────────────────
# Your domain name (no https://, no trailing slash)
DOMAIN=app.yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password — deploy.sh generates this automatically
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Storage (MinIO) ──────────────────────────────────────────────────────────
MINIO_ROOT_USER=clauseflow
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Auth ──────────────────────────────────────────────────────────────────────
# 32+ random bytes — deploy.sh generates this automatically
BETTER_AUTH_SECRET=REPLACE_WITH_SECRET

# ── Notification encryption (required for Slack/Teams webhooks) ───────────────
# 32+ random bytes — deploy.sh generates this automatically
NOTIFICATION_ENCRYPTION_KEY=REPLACE_WITH_SECRET

# ── Email (Resend — free tier: 100 emails/day) ────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API key
# Then verify your domain in Resend and add the DNS records they give you
RESEND_API_KEY=re_REPLACE_WITH_YOUR_RESEND_KEY
SMTP_FROM=noreply@yourdomain.com
ALERT_EMAIL_TO=your@email.com

# ── DocuSeal (e-signatures) ──────────────────────────────────────────────────
# deploy.sh generates DOCUSEAL_SECRET_KEY_BASE automatically
DOCUSEAL_SECRET_KEY_BASE=REPLACE_WITH_SECRET
# After first deploy, log into sign.yourdomain.com → API → copy the key here,
# then restart: docker compose -f docker-compose.prod.yml restart app worker
DOCUSEAL_API_KEY=
DOCUSEAL_WEBHOOK_SECRET=

# ── AI (optional — leave empty, users bring their own keys) ──────────────────
# You can set global keys here if you want to offer managed AI,
# or leave empty and let each user configure their own in Settings.
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
