# ── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal
# Defaults to "debug" in development, "info" in production.
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/clauseflow
# Required when running via docker-compose; postgres container will refuse to
# boot without it. Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=
DATABASE_POOL_SIZE=20        # Postgres connection pool size per process (app + worker each)

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -base64 32
# docker-compose will refuse to start the app container if this is empty.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# INTERNAL_APP_URL: used for SSR self-requests (e.g. analytics page fetching its own API).
# Set this to the container-internal address when running in Docker (e.g. http://app:3000)
# so the server-side fetch does not route through the public URL which is unreachable inside
# the container network.
INTERNAL_APP_URL=http://localhost:3000

# ── Storage (S3-compatible) ───────────────────────────────────────────────────
# Leave STORAGE_ENDPOINT empty for AWS S3, set for MinIO or other S3-compatible
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=clauseflow
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1

# ── AI (required for M1 AI extraction — optional, degrades gracefully without)
# AI_PROVIDER auto-detects from which key is set. Override explicitly if needed.
# Values: anthropic | openai | ollama
AI_PROVIDER=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
# OLLAMA_EMBEDDING_MODEL: Embedding model to use with Ollama (self-hosted embeddings).
# IMPORTANT: must produce 1536-dim vectors to match the ContractEmbedding column.
# The default `nomic-embed-text` model produces 768-dim vectors and WILL FAIL.
# Use a 1536-dim model such as `mxbai-embed-large` instead.
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# ── Email / SMTP (required for M1 renewal alerts — optional, app works without)
# Leave SMTP_HOST empty to disable email sending entirely.
SMTP_HOST=
SMTP_PORT=587
# Set SMTP_SECURE=true for TLS (port 465), false for STARTTLS (port 587)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourcompany.com
# Comma-separated list of recipients for alert emails
ALERT_EMAIL_TO=

# ── Redis (required for BullMQ job queues) ───────────────────────────────────
REDIS_URL=redis://localhost:6379
# Optional — when set, the docker-compose redis container starts with
# `--requirepass`. Update REDIS_URL to redis://:${REDIS_PASSWORD}@redis:6379
# in your env when running via docker-compose with a password.
REDIS_PASSWORD=

# ── E-signature (DocuSeal) — self-hosted at port 3001 or use DocuSeal Cloud ──
# DOCUSEAL_API_URL: omit (or set to https://api.docuseal.com) to use DocuSeal Cloud.
# For docker-compose self-hosted set to http://localhost:3001 (or http://docuseal:3000 inside Docker).
DOCUSEAL_API_URL=http://localhost:3001
DOCUSEAL_API_KEY=your_docuseal_api_key
# Required — reject all DocuSeal webhook events if not set (fail-secure).
# All incoming webhook requests must carry a valid HMAC-SHA256 signature in the
# X-DocuSeal-Signature header. Set this in the DocuSeal dashboard → Webhooks section.
# Without this variable the webhook handler returns 403 for every request.
DOCUSEAL_WEBHOOK_SECRET=your_docuseal_webhook_secret_here
# DOCUSEAL_SECRET_KEY_BASE: Required only for docker-compose self-hosted DocuSeal.
# Generate with: openssl rand -hex 64
DOCUSEAL_SECRET_KEY_BASE=

# ── Encryption (for API keys stored in DB) ────────────────────────────────────
ENCRYPTION_KEY=

# ── Slack / Teams webhook alerts (optional — degrades gracefully when not set) ─
# Slack incoming webhook URL
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Microsoft Teams incoming webhook URL
# Create at: Teams channel → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=

# ── M5 Notification encryption (REQUIRED for Slack/Teams/webhook routing) ────
# Required for M5 notification encryption (hex-encoded 32-byte key)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NOTIFICATION_ENCRYPTION_KEY=

# ── M6 Authoring (DOCX export) ───────────────────────────────────────────────
# Optional — font family used in exported .docx files (default: Times New Roman)
DOCX_EXPORT_FONT=

# ── CRM Integrations (optional — required only if enabling CRM features) ──────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# ── Google Drive Import (optional — required only if enabling Google Drive import)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
