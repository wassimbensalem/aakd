generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth tables ───────────────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  locale        String   @default("en")
  createdAt     DateTime
  updatedAt     DateTime

  sessions      Session[]
  accounts      Account[]
  memberships   Member[]
  ownedContracts Contract[]    @relation("ContractOwner")
  uploadedFiles  ContractFile[]
  versions       ContractVersion[]
  activities     Activity[]
  apiKeys        ApiKey[]
  approvalRequests    Approval[] @relation("ApprovalRequester")
  approvalAssignments Approval[] @relation("ApprovalAssignee")
  createdNotificationChannels OrgNotificationChannel[] @relation("NotificationChannelCreatedBy")
  createdOutboundWebhooks     OutboundWebhook[]        @relation("OutboundWebhookCreatedBy")
  notificationPreferences     UserNotificationPreference[]
  savedDocuments              ContractDocument[]       @relation("DocumentSaver")
  createdTemplates            ContractTemplate[]       @relation("TemplateCreator")
  updatedTemplates            ContractTemplate[]       @relation("TemplateUpdater")
  obligationsAssigned         ContractObligation[]     @relation("ObligationAssignee")
  obligationsCompleted        ContractObligation[]     @relation("ObligationCompleter")
  obligationsCreated          ContractObligation[]     @relation("ObligationCreator")
  subTasksCompleted           ObligationSubTask[]      @relation("SubTaskCompleter")
  crmIntegrationsConnected    CrmIntegration[]         @relation("CrmIntegrationConnectedBy")
  crmLinksCreated             CrmLink[]                @relation("CrmLinkCreator")
  importJobsCreated           ImportJob[]              @relation("ImportJobCreator")
  googleDriveConnected        GoogleDriveIntegration[] @relation("GoogleDriveConnectedBy")
  notifications               Notification[]
  commentsAuthored            ContractComment[]        @relation("CommentAuthor")
  commentsResolved            ContractComment[]        @relation("CommentResolver")
  snapshotsCreated            DocumentSnapshot[]       @relation("SnapshotCreator")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String   @unique
  createdAt            DateTime
  updatedAt            DateTime
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

model Organization {
  id          String   @id
  name        String
  slug        String   @unique
  logo        String?
  createdAt   DateTime
  metadata    String?

  members     Member[]
  invitations Invitation[]
  contracts   Contract[]
  folders     Folder[]
  tags        Tag[]
  apiKeys     ApiKey[]
  notificationChannels    OrgNotificationChannel[]
  outboundWebhooks        OutboundWebhook[]
  notificationPreferences UserNotificationPreference[]
  templates               ContractTemplate[]
  snapshots               DocumentSnapshot[]
  obligations             ContractObligation[]
  crmIntegrations         CrmIntegration[]
  importJobs              ImportJob[]
  googleDriveIntegration  GoogleDriveIntegration?
  notifications           Notification[]
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       // "admin" | "legal" | "member" | "viewer"
  createdAt      DateTime

  @@unique([userId, organizationId])
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String
  expiresAt      DateTime
  inviterId      String
}

// ─── API Keys ─────────────────────────────────────────────────────────────────

model ApiKey {
  id             String       @id @default(cuid())
  name           String
  keyHash        String       @unique   // bcrypt hash — never store plaintext
  lookupHash     String       @unique   // SHA-256 for fast DB lookup
  prefix         String                 // "cf_live_sk_abc1..." shown in UI list
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User         @relation(fields: [createdById], references: [id])
  scopes         String[]     @default(["read"])
  lastUsedAt     DateTime?
  expiresAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime     @default(now())
}

// ─── Contracts ────────────────────────────────────────────────────────────────

model Contract {
  id                  String         @id @default(cuid())
  title               String
  contractType        ContractType?
  status              ContractStatus @default(DRAFT)
  ownerId             String
  owner               User           @relation("ContractOwner", fields: [ownerId], references: [id])
  counterpartyName    String?
  counterpartyContact String?
  value               Float?
  currency            String?        @default("USD")
  governingLaw        String?
  startDate           DateTime?
  endDate             DateTime?
  renewalDate         DateTime?
  noticePeriodDays    Int?
  autoRenewal         Boolean        @default(false)
  notes               String?
  organizationId      String
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  folderId            String?
  folder              Folder?        @relation(fields: [folderId], references: [id])
  files               ContractFile[]
  versions            ContractVersion[]
  activities          Activity[]
  tags                Tag[]
  extractions         AIExtraction[]
  alerts              ContractAlert[]
  approvals           Approval[]
  embedding           ContractEmbedding?
  document              ContractDocument?
  snapshots             DocumentSnapshot[]
  comments              ContractComment[]
  obligations           ContractObligation[]
  crmLinks              CrmLink[]
  notifications         Notification[]
  extractedText         String?
  docusealSubmissionId  String?
  signingUrl            String?
  signingStatus         String?
  signers               ContractSigner[]
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([organizationId, updatedAt])
  @@index([docusealSubmissionId])
}

model ContractSigner {
  id         String    @id @default(cuid())
  contractId String
  contract   Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  name       String
  email      String
  isInternal Boolean   @default(false)
  status     String    @default("not_sent") // "not_sent" | "pending" | "signed" | "declined"
  signedAt   DateTime?
  externalId String?   // DocuSeal submitter slug — populated after submission created
  createdAt  DateTime  @default(now())

  @@index([contractId])
}

enum ContractType {
  NDA
  MSA
  SOW
  EMPLOYMENT
  VENDOR
  CUSTOMER
  OTHER
}

enum ContractStatus {
  DRAFT
  INTERNAL_REVIEW
  PENDING_APPROVAL
  AWAITING_SIGNATURE
  ACTIVE
  EXPIRED
  TERMINATED
  ARCHIVED
}

model ContractFile {
  id           String   @id @default(cuid())
  contractId   String
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  filename     String
  storageKey   String
  mimeType     String
  sizeBytes    Int
  isSigned     Boolean  @default(false)
  isLatest     Boolean  @default(true)
  version      Int      @default(1)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([contractId])
}

model ContractVersion {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  version     Int
  changeNote  String?
  fileId      String?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([contractId])
}

model Activity {
  id          String         @id @default(cuid())
  contractId  String
  contract    Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?          @relation(fields: [userId], references: [id])
  actorLabel  String         @default("System")
  action      ActivityAction
  detail      String?
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([contractId])
}

enum ActivityAction {
  CREATED
  UPLOADED
  UPDATED
  STATUS_CHANGED
  COMMENTED
  APPROVAL_REQUESTED
  APPROVED
  REJECTED
  SENT_FOR_SIGNATURE
  SIGNED
  ALERT_FIRED
  METADATA_EXTRACTED
  METADATA_UPDATED
  DOWNLOADED
  DELETED
  ARCHIVED
  TAGGED
  DOCUMENT_SAVED
  DOCUMENT_IMPORTED
  DOCUMENT_EXPORTED
  OBLIGATION_CREATED
  OBLIGATION_UPDATED
  OBLIGATION_COMPLETED
  OBLIGATION_DELETED
  CRM_LINKED
  CRM_UNLINKED
  CRM_SYNCED
  IMPORT_COMPLETED
  APPROVAL_CANCELLED
  SNAPSHOT_CREATED
  SNAPSHOT_DELETED
}

model Folder {
  id             String       @id @default(cuid())
  name           String
  parentId       String?
  parent         Folder?      @relation("subfolders", fields: [parentId], references: [id])
  children       Folder[]     @relation("subfolders")
  contracts      Contract[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}

model Tag {
  id             String       @id @default(cuid())
  name           String
  color          String?      @default("#6366f1")
  contracts      Contract[]
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([name, organizationId])
}

// ─── M1: AI Extraction ───────────────────────────────────────────────────────

model AIExtraction {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  field       String   // contractType | startDate | endDate | renewalDate | value | parties | governingLaw | noticePeriodDays | autoRenewal
  rawValue    String?
  confidence  Float    @default(0)
  sourceText  String?
  sourcePage  Int?
  extractedBy String   @default("ai")
  status      String   @default("pending") // pending | accepted | rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([contractId, field])
}

// ─── M1: Renewal Alerts ──────────────────────────────────────────────────────

model ContractAlert {
  id          String    @id @default(cuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  alertType   String    // EXPIRY_30 | EXPIRY_60 | EXPIRY_90 | RENEWAL_DUE | NOTICE_PERIOD
  triggerDate DateTime
  firedAt     DateTime?
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([contractId])
}

// ─── M3: Semantic Embeddings ──────────────────────────────────────────────────

model ContractEmbedding {
  id         String   @id @default(cuid())
  contractId String   @unique
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  model      String   @default("text-embedding-3-small")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ContractEmbedding")
}

// Backed by pgvector via raw SQL. The embedding column exists in the database
// but is intentionally not represented here because Prisma has no native vector
// scalar. See migration 20260508130000_m3_contract_chunk_embeddings.

// ─── M2: Approval Workflow ────────────────────────────────────────────────────

model Approval {
  id             String    @id @default(cuid())
  contractId     String
  contract       Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User      @relation("ApprovalRequester", fields: [requestedById], references: [id])
  assignedToId   String
  assignedTo     User      @relation("ApprovalAssignee", fields: [assignedToId], references: [id])
  status         String    @default("pending") // pending | approved | rejected | waiting
  required       Boolean   @default(true)
  step           Int       @default(1)
  comment        String?
  decidedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([contractId])
}

// ─── M5: Ecosystem Notifications ─────────────────────────────────────────────

model OrgNotificationChannel {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channelType    String       // "slack" | "teams"
  webhookUrl     String       // AES-256-GCM encrypted at rest
  label          String       // max 100 chars
  enabled        Boolean      @default(true)
  createdById    String
  createdBy      User         @relation("NotificationChannelCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model OutboundWebhook {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  url            String       // AES-256-GCM encrypted at rest
  label          String       // max 100 chars
  signingSecret  String       // 32-byte hex, AES-256-GCM encrypted at rest
  enabled        Boolean      @default(true)
  createdById    String
  createdBy      User         @relation("OutboundWebhookCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  deliveryLogs   WebhookDeliveryLog[]
}

// Cascade behavior: deleting an OutboundWebhook removes all of its
// WebhookDeliveryLog rows. The audit history is intentionally tied to the
// webhook lifecycle — once the webhook is removed, its delivery history is
// no longer relevant and is purged with it.
model WebhookDeliveryLog {
  id           String          @id @default(cuid())
  webhookId    String
  webhook      OutboundWebhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  eventName    String          // one of the 10 canonical event names
  contractId   String
  payload      Json            // full envelope sent in the request body
  attempt      Int             // 1 | 2 | 3
  httpStatus   Int?            // null on network error
  responseBody String?         // first 1000 chars of response body, null on network error
  durationMs   Int?            // round-trip ms, null on network error
  status       String          // "pending" | "success" | "failed"
  deliveredAt  DateTime?       // set on success
  createdAt    DateTime        @default(now())
}

model UserNotificationPreference {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventName      String       // one of the 10 canonical event names
  emailEnabled   Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId, eventName])
}

// ─── M6: Authoring ────────────────────────────────────────────────────────────

model ContractDocument {
  id           String   @id @default(cuid())
  contractId   String   @unique
  contract     Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  content      Json     // Plate JSON — array of top-level Plate nodes
  wordCount    Int      @default(0)
  version      Int      @default(1)
  savedById    String
  savedBy      User     @relation("DocumentSaver", fields: [savedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── M12: Document Snapshots (Redlining) ─────────────────────────────────────

model DocumentSnapshot {
  id             String       @id @default(cuid())
  contractId     String
  contract       Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String       // e.g. "Before client review", max 200 chars
  content        Json         // TipTap JSON — full snapshot of editor content
  wordCount      Int          @default(0)
  createdById    String
  createdBy      User         @relation("SnapshotCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([contractId, createdAt])
  @@index([organizationId])
}

model ContractComment {
  id           String    @id @default(cuid())
  contractId   String
  contract     Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
  authorId     String
  author       User      @relation("CommentAuthor", fields: [authorId], references: [id])
  body         String
  markId       String?   // TipTap comment mark ID linking this comment to highlighted text
  resolved     Boolean   @default(false)
  resolvedById String?
  resolvedBy   User?     @relation("CommentResolver", fields: [resolvedById], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([contractId])
}

model ContractTemplate {
  id             String        @id @default(cuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  contractType   ContractType?
  content        Json
  variables      Json
  wordCount      Int           @default(0)
  createdById    String
  createdBy      User          @relation("TemplateCreator", fields: [createdById], references: [id])
  updatedById    String
  updatedBy      User          @relation("TemplateUpdater", fields: [updatedById], references: [id])
  isArchived     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([organizationId, isArchived])
}

// ─── M7: Obligation Tracking ──────────────────────────────────────────────────

model ContractObligation {
  id              String              @id @default(cuid())
  contractId      String
  contract        Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  title           String
  description     String?
  clauseReference String?
  priority        ObligationPriority  @default(MEDIUM)
  status          ObligationStatus    @default(PENDING)
  dueDate         DateTime

  assigneeId      String?
  assignee        User?               @relation("ObligationAssignee", fields: [assigneeId], references: [id])

  reminderDays    Int                 @default(7)
  reminderSentAt  DateTime?

  completedAt     DateTime?
  completedById   String?
  completedBy     User?               @relation("ObligationCompleter", fields: [completedById], references: [id])

  createdById     String
  createdBy       User                @relation("ObligationCreator", fields: [createdById], references: [id])

  subTasks        ObligationSubTask[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([contractId])
  @@index([organizationId, status])
  @@index([status, dueDate])
}

model ObligationSubTask {
  id            String              @id @default(cuid())
  obligationId  String
  obligation    ContractObligation  @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  title         String
  isCompleted   Boolean             @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?               @relation("SubTaskCompleter", fields: [completedById], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([obligationId])
}

enum ObligationStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum ObligationPriority {
  LOW
  MEDIUM
  HIGH
}

// ─── M9: CRM Integrations ─────────────────────────────────────────────────────

model CrmIntegration {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider       CrmProvider
  accessToken    String
  refreshToken   String?
  tokenExpiresAt DateTime?
  instanceUrl    String?
  portalId       String?

  autoCreateStage   String?
  syncOnActiveStage String?

  connectedById  String
  connectedBy    User         @relation("CrmIntegrationConnectedBy", fields: [connectedById], references: [id])

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  links          CrmLink[]

  @@unique([organizationId, provider])
  @@index([organizationId])
}

model CrmLink {
  id               String         @id @default(cuid())
  contractId       String
  contract         Contract       @relation(fields: [contractId], references: [id], onDelete: Cascade)
  integrationId    String
  integration      CrmIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  provider         CrmProvider
  externalDealId   String
  externalDealName String
  externalDealUrl  String?

  lastSyncedAt     DateTime?
  lastSyncStatus   String?

  createdById      String
  createdBy        User           @relation("CrmLinkCreator", fields: [createdById], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([contractId, integrationId])
  @@index([contractId])
  @@index([integrationId])
  @@index([provider, externalDealId])
}

enum CrmProvider {
  HUBSPOT
  SALESFORCE
  PIPEDRIVE
}

// ─── M10: Migration / Import Tools ────────────────────────────────────────────

model ImportJob {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source         ImportSource
  status         ImportStatus @default(PENDING)
  storageKey     String?
  driveFileIds   String?
  mappingJson    String?
  totalRows      Int          @default(0)
  succeededRows  Int          @default(0)
  failedRows     Int          @default(0)
  errorReportKey String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdById    String
  createdBy      User         @relation("ImportJobCreator", fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  rows           ImportRow[]

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model ImportRow {
  id           String    @id @default(cuid())
  jobId        String
  job          ImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  rowIndex     Int
  sourceRef    String
  status       String    @default("pending")
  errorMessage String?
  contractId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([jobId, status])
  @@index([jobId, rowIndex])
}

model GoogleDriveIntegration {
  id             String       @id @default(cuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime?
  connectedById  String
  connectedBy    User         @relation("GoogleDriveConnectedBy", fields: [connectedById], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

enum ImportSource {
  CSV
  BATCH_FILES
  GOOGLE_DRIVE
  PANDADOC
  CLM_EXPORT
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ─── In-app Notifications ─────────────────────────────────────────────────────

model Notification {
  id             String    @id @default(cuid())
  userId         String
  organizationId String
  contractId     String?
  eventName      String
  title          String
  body           String
  read           Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?    @relation(fields: [contractId], references: [id], onDelete: SetNull)

  @@index([userId, read, createdAt])
  @@index([organizationId])
}
