{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:isolation": "vitest run --reporter=verbose tests/security/org-isolation.test.ts",
    "worker:dev": "tsx --tsconfig tsconfig.worker.json watch worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@aws-sdk/client-s3": "^3.1043.0",
