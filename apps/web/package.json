    "@base-ui/react": "^1.4.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.9",
    "bullmq": "^5.76.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.7",
    "openai": "^6.36.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
